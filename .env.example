SERVER_PORT=8080
VOICE_BUILDER_DATA_DIR=./data
VOICE_BUILDER_OUTPUT_DIR=./voices
TRAINER_DIR=./supertonic3-voice-clone
TRAINER_GIT_URL=https://github.com/saurabhv749/supertonic3-voice-clone.git
TRAINER_ARCHIVE_URL=https://github.com/saurabhv749/supertonic3-voice-clone/archive/refs/heads/main.zip
TRAINER_BACKUP_DIR=./trainer-backup
TRAINER_BOOTSTRAP_ENABLED=true
PYTHON_BIN=./venv/bin/python3
WORKER_SCRIPT=./worker/train_voice.py
OMP_NUM_THREADS=16
MKL_NUM_THREADS=16
MAX_CONCURRENT_JOBS=1
DEFAULT_STEPS=3000
DEFAULT_LEARNING_RATE=0.0002
