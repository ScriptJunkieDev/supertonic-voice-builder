    "scripts": {
        "installation": {
            "script": "#!/bin/bash\nset -euo pipefail\ncd /mnt/server\necho \"Running Supertonic Voice Builder egg install (./venv + pip deps)...\"\ncurl -fsSL https://raw.githubusercontent.com/ScriptJunkieDev/supertonic-voice-builder/main/pterodactyl/install-voice-builder-deps.sh | bash\necho \"Egg install finished.\"\n",
            "container": "ghcr.io/pterodactyl/installers:debian",
            "entrypoint": "bash"
        }
    },
